<Window x:Class="ChiptuningAi.Dashboard.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Patch"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDark}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="24,20">
        <TextBlock Text="RENAME PATCH" FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,16"/>

        <Label Content="Description" Foreground="{DynamicResource TextSecondary}" FontSize="11" Padding="0,0,0,4"/>
        <TextBox x:Name="DescriptionBox"
                 Style="{StaticResource DarkTextBox}"
                 Margin="0,0,0,12"/>

        <Label Content="Version" Foreground="{DynamicResource TextSecondary}" FontSize="11" Padding="0,0,0,4"/>
        <TextBox x:Name="VersionBox"
                 Style="{StaticResource DarkTextBox}"
                 Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource GhostButton}"
                    Margin="0,0,8,0" Padding="14,8" IsCancel="True"/>
            <Button Content="Save" Style="{StaticResource AccentButton}"
                    Padding="14,8" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
