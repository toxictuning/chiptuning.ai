<Window x:Class="ChiptuningAi.Dashboard.FileDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Detail"
        Height="720" Width="900"
        MinHeight="560" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDark}"
        WindowStyle="None"
        AllowsTransparency="True"
        StateChanged="Window_StateChanged">

    <Border Background="{DynamicResource BgDark}" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgMid}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0"
                                   Foreground="{DynamicResource AccentButtonBg}"/>
                        <TextBlock x:Name="TitleText" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="—" Click="Minimize_Click" Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" Width="28"/>
                        <Button x:Name="MaxBtn" Content="☐" Click="Maximize_Click"
                                Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Width="28"/>
                        <Button Content="✕" Click="Close_Click" Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Width="28"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left sidebar: file metadata -->
                <Border Grid.Column="0" Background="{DynamicResource BgMid}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,20">
                        <StackPanel>
                            <!-- Loading state -->
                            <TextBlock x:Name="SidebarLoading" Text="Loading…"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="13"/>

                            <!-- File info block -->
                            <StackPanel x:Name="SidebarContent" Visibility="Collapsed">

                                <TextBlock Text="FILE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>

                                <TextBlock x:Name="InfoFileName" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock x:Name="InfoFileSize" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="HASHES" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="MD5" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="InfoMD5" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" FontFamily="Consolas"
                                           Margin="0,2,0,8"/>
                                <TextBlock Text="SHA-256" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="InfoHash" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" FontFamily="Consolas"
                                           Margin="0,2,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="VEHICLE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="InfoVehicle" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="ECU / CONTROLLER" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="InfoEcu" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock x:Name="InfoRead" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="UPLOADED" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="InfoUploadedAt" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="InfoUploadedBy" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap"/>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Right content: tabs for patches and chunk hashes -->
                <Grid Grid.Column="1" Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab strip -->
                    <Border Grid.Row="0" Background="{DynamicResource BgMid}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="16,0">
                            <Button x:Name="TabPatches" Content="PATCHES"
                                    Style="{StaticResource GhostButton}"
                                    Click="TabPatches_Click" Padding="12,10" FontSize="11" FontWeight="Bold"/>
                            <Button x:Name="TabChunks" Content="DNA"
                                    Style="{StaticResource GhostButton}"
                                    Click="TabChunks_Click" Padding="12,10" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Patches panel -->
                    <Grid x:Name="PanelPatches" Grid.Row="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="PatchesGrid" Grid.Row="0" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Version"     Binding="{Binding Version}"     Width="80"/>
                                <DataGridTextColumn Header="Size (KB)"   Binding="{Binding SizeKb}"      Width="80"/>
                                <DataGridTextColumn Header="Active"      Binding="{Binding IsActive}"    Width="60"/>
                                <DataGridTextColumn Header="Created"     Binding="{Binding Created}"     Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="PatchesStatus" Grid.Row="1"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12" Margin="0,8,0,0"/>
                    </Grid>

                    <!-- Chunk hashes panel -->
                    <Grid x:Name="PanelChunks" Grid.Row="1" Margin="20" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="ChunksHeader" Grid.Row="0" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
                        <ListBox x:Name="ChunksList" Grid.Row="1"
                                 Background="{DynamicResource BgMid}"
                                 BorderBrush="{DynamicResource Border}"
                                 FontFamily="Consolas" FontSize="11"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
