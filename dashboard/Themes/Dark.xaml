<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Colours (Color resources for animated inline brushes) ──────────── -->
    <Color x:Key="InputBorderColor">#2A2A2A</Color>
    <Color x:Key="InputFocusColor">#E8E8E8</Color>

    <!-- ── Brushes ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgDark"           Color="#0C0C0C"/>
    <SolidColorBrush x:Key="BgMid"            Color="#141414"/>
    <SolidColorBrush x:Key="BgPanel"          Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextPrimary"      Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextSecondary"    Color="#606060"/>
    <SolidColorBrush x:Key="Border"           Color="#242424"/>

    <!-- Accent (default mono — overridden at runtime by swatch) -->
    <SolidColorBrush x:Key="AccentButtonBg"   Color="#E8E8E8"/>
    <SolidColorBrush x:Key="AccentButtonFg"   Color="#0C0C0C"/>
    <SolidColorBrush x:Key="InputFocusBrush"  Color="#E8E8E8"/>

    <!-- Ghost button -->
    <SolidColorBrush x:Key="GhostButtonBg"       Color="#1C1C1C"/>
    <SolidColorBrush x:Key="GhostButtonBgHover"  Color="#282828"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBg"          Color="#161616"/>
    <SolidColorBrush x:Key="PlaceholderFg"    Color="#3A3A3A"/>

    <!-- Data grid -->
    <SolidColorBrush x:Key="DataGridRow"      Color="#141414"/>
    <SolidColorBrush x:Key="DataGridAltRow"   Color="#111111"/>
    <SolidColorBrush x:Key="DataGridHeader"   Color="#1A1A1A"/>
    <SolidColorBrush x:Key="DataGridSel"      Color="#2A2A2A"/>
    <SolidColorBrush x:Key="DataGridSelFg"    Color="#F0F0F0"/>

    <!-- Drop zone -->
    <SolidColorBrush x:Key="DropZoneBorder"   Color="#2A2A2A"/>
    <SolidColorBrush x:Key="DropZoneBorderHover" Color="#505050"/>

</ResourceDictionary>
