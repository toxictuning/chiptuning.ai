<Window x:Class="ChiptuningAi.Dashboard.FileDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Detail"
        Height="720" Width="960"
        MinHeight="560" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDark}"
        WindowStyle="None"
        AllowsTransparency="True"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <!-- Pill-shaped toggle switch: OFF = dark track, ON = accent colour -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Cursor"    Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="38" Height="20" VerticalAlignment="Center">
                            <Border x:Name="Track" CornerRadius="10" Background="#3A3A3A"/>
                            <Ellipse x:Name="Thumb" Width="14" Height="14"
                                     Fill="White" HorizontalAlignment="Left"
                                     VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentButtonBg}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgDark}" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgMid}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0"
                                   Foreground="{DynamicResource AccentButtonBg}"
                                   FontFamily="Segoe UI Emoji, Segoe UI"/>
                        <TextBlock x:Name="TitleText" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="—" Click="Minimize_Click" Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" Width="28"/>
                        <Button x:Name="MaxBtn" Content="☐" Click="Maximize_Click"
                                Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Width="28"/>
                        <Button Content="✕" Click="Close_Click" Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Width="28"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left sidebar: file metadata -->
                <Border Grid.Column="0" Background="{DynamicResource BgMid}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,20">
                        <StackPanel>
                            <!-- Loading state -->
                            <TextBlock x:Name="SidebarLoading" Text="Loading…"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="13"/>

                            <!-- File info block -->
                            <StackPanel x:Name="SidebarContent" Visibility="Collapsed">

                                <TextBlock Text="FILE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>

                                <TextBlock x:Name="InfoFileName" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock x:Name="InfoFileSize" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="HASHES" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="MD5" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="InfoMD5" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" FontFamily="Consolas"
                                           Margin="0,2,0,8"/>
                                <TextBlock Text="SHA-256" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="InfoHash" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" FontFamily="Consolas"
                                           Margin="0,2,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="VEHICLE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="InfoVehicle" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="ECU / CONTROLLER" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="InfoEcu" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock x:Name="InfoRead" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,0,0,12"/>

                                <TextBlock Text="UPLOADED" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="InfoUploadedAt" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="InfoUploadedBy" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap"/>

                                <Separator Background="{DynamicResource Border}" Margin="0,14,0,12"/>

                                <Button x:Name="EditMetadataBtn"
                                        Content="Edit Metadata"
                                        Style="{StaticResource GhostButton}"
                                        HorizontalAlignment="Stretch"
                                        Click="EditMetadata_Click"/>
                                <Button x:Name="DownloadOriginalBtn"
                                        Content="Download Original"
                                        Style="{StaticResource GhostButton}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,4,0,0"
                                        ToolTip="Download original unmodified ECU file"
                                        Click="DownloadOriginal_Click"/>

                            </StackPanel>

                            <!-- Edit metadata form -->
                            <StackPanel x:Name="SidebarEdit" Visibility="Collapsed" Margin="0,8,0,0">

                                <TextBlock Text="EDIT METADATA" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>

                                <TextBlock Text="Vehicle Class" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditVehicleClass" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="Make" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditVehicleMake" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="Model" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditVehicleModel" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="Variant" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditVehicleVariant" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="Engine Type" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditEngineType" Style="{StaticResource DarkTextBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="ECU Type" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditECUType" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="ECU Make" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditECUMake" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="ECU Model" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                <TextBox x:Name="EditECUModel" Style="{StaticResource DarkTextBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Read Hardware" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditReadHardware" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="Read Mode" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditReadMode" Style="{StaticResource DarkTextBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="HW Number (optional)" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditHWNumber" Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>

                                <TextBlock Text="SW Number (optional)" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                <TextBox x:Name="EditSWNumber" Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

                                <TextBlock x:Name="EditStatus" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Cancel"
                                            Style="{StaticResource GhostButton}"
                                            Margin="0,0,4,0" HorizontalAlignment="Stretch"
                                            Click="EditCancel_Click"/>
                                    <Button Grid.Column="1" Content="Save"
                                            Style="{StaticResource AccentButton}"
                                            Margin="4,0,0,0" HorizontalAlignment="Stretch"
                                            Click="EditSave_Click"/>
                                </Grid>

                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Right content: patches panel -->
                <Border Grid.Column="1" Background="{DynamicResource BgPanel}">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Patches panel -->
                    <Grid x:Name="PanelPatches" Grid.Row="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="PatchesGrid" Grid.Row="0" IsReadOnly="True"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  HorizontalScrollBarVisibility="Auto"
                                  HorizontalAlignment="Stretch">
                            <DataGrid.Columns>
                                <!-- Toggle switch column: ON = apply, OFF = skip/remove -->
                                <DataGridTemplateColumn Header="" Width="58" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- Grid stretches to fill the cell; ToggleButton centers within it -->
                                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <ToggleButton IsChecked="{Binding IsApplied, Mode=OneWay}"
                                                              Style="{StaticResource ToggleSwitch}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Click="SolutionToggle_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Version"     Binding="{Binding Version}"     Width="70"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Size (KB)"   Binding="{Binding SizeKb}"      Width="72"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Created"     Binding="{Binding Created}"     Width="106" IsReadOnly="True"/>
                                <DataGridTemplateColumn x:Name="PatchActionsColumn" Header="Actions" Width="200" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,0">
                                                <Button Content="Rename"
                                                        Tag="{Binding PatchId}"
                                                        Style="{StaticResource GhostButton}"
                                                        Padding="6,3" FontSize="11" Margin="0,0,4,0"
                                                        Click="RenamePatch_Click"/>
                                                <Button Content="Replace"
                                                        Tag="{Binding PatchId}"
                                                        Style="{StaticResource GhostButton}"
                                                        Padding="6,3" FontSize="11" Margin="0,0,4,0"
                                                        Click="ReplacePatch_Click"/>
                                                <Button Content="Delete"
                                                        Tag="{Binding PatchId}"
                                                        Style="{StaticResource GhostButton}"
                                                        Padding="6,3" FontSize="11"
                                                        Foreground="#EF4444"
                                                        Click="DeletePatch_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="PatchesStatus" Grid.Row="1"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12" Margin="0,8,0,0"/>

                        <!-- Generate strip -->
                        <Border Grid.Row="2" Margin="0,10,0,0"
                                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                                Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="GENERATE — toggle solutions on/off then generate"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="GenerateSourcePath" Grid.Column="0"
                                             Style="{StaticResource DarkTextBox}"
                                             IsReadOnly="True" Margin="0,0,6,0"
                                             Text="Drop source ECU file here or Browse…"
                                             AllowDrop="True"
                                             Drop="GenerateSource_Drop"
                                             DragOver="GenerateSource_DragOver"
                                             ToolTip="Source ECU file to apply the selected solutions to"/>
                                    <Button Grid.Column="1" Content="Browse…"
                                            Style="{StaticResource GhostButton}"
                                            Margin="0,0,6,0" Padding="8,6"
                                            ToolTip="Select source ECU binary"
                                            Click="BrowseGenerateSource_Click"/>
                                    <Button Grid.Column="2" Content="Generate"
                                            Style="{StaticResource AccentButton}"
                                            Padding="14,6"
                                            ToolTip="Apply selected solutions to the source file and save result"
                                            Click="Generate_Click"/>
                                </Grid>
                                <TextBlock x:Name="GenerateStatus"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Patch upload strip -->
                        <Border x:Name="UploadSolutionStrip" Grid.Row="3" Margin="0,10,0,0"
                                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                                Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="UPLOAD SOLUTION" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PatchFilePath" Grid.Column="0"
                                             Style="{StaticResource DarkTextBox}"
                                             IsReadOnly="True" Margin="0,0,6,0"
                                             Text="No file selected"
                                             AllowDrop="True"
                                             Drop="PatchZone_Drop"
                                             DragOver="PatchZone_DragOver"
                                             ToolTip="Drag and drop the modified (tuned) ECU file here, or use Browse"/>
                                    <Button Grid.Column="1" Content="Browse…"
                                            Style="{StaticResource GhostButton}"
                                            Margin="0,0,6,0" Padding="8,6"
                                            ToolTip="Select the modified ECU binary file"
                                            Click="BrowsePatch_Click"/>
                                    <TextBox x:Name="PatchDescription" Grid.Column="2"
                                             Style="{StaticResource DarkTextBox}"
                                             Margin="0,0,6,0"
                                             Text="Description"
                                             ToolTip="Short description of this solution (e.g. Stage 1 +30hp)"/>
                                    <TextBox x:Name="PatchVersion" Grid.Column="3"
                                             Style="{StaticResource DarkTextBox}"
                                             Margin="0,0,6,0"
                                             Text="v1.0"
                                             ToolTip="Version label for this solution"/>
                                    <Button Grid.Column="4" Content="Upload"
                                            Style="{StaticResource AccentButton}"
                                            Padding="14,6"
                                            ToolTip="Upload the modified ECU file as a solution for this record"
                                            Click="UploadPatch_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="PatchUploadStatus" Grid.Row="4"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" Margin="0,6,0,0"/>
                    </Grid>
                </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
