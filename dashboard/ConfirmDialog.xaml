<Window x:Class="ChiptuningAi.Dashboard.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDark}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource BgPanel}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1">
        <StackPanel Margin="28,22">

            <!-- Header -->
            <Grid Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="IconText" Text="⚠" FontSize="16"
                               Foreground="{DynamicResource AccentButtonBg}"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               FontFamily="Segoe UI Emoji, Segoe UI"/>
                    <TextBlock x:Name="TitleText" Text="CONFIRM" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                       FontSize="13"
                       Foreground="{DynamicResource TextPrimary}"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="0,0,0,8"/>

            <!-- Sub-message -->
            <TextBlock x:Name="SubText"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondary}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,0,0,22"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button x:Name="CancelBtn" Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Padding="18,8" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button x:Name="ConfirmBtn" Content="Confirm"
                        Style="{StaticResource AccentButton}"
                        Padding="18,8"
                        Click="Confirm_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
