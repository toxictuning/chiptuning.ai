<Window x:Class="ChiptuningAi.Dashboard.ProcessingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Processing"
        Height="680" Width="1000"
        MinHeight="520" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDark}"
        WindowStyle="None"
        AllowsTransparency="True"
        StateChanged="Window_StateChanged">

    <Border Background="{DynamicResource BgDark}" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgMid}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="⚙" FontSize="14" Margin="0,0,8,0"
                                   Foreground="{DynamicResource AccentButtonBg}"/>
                        <TextBlock Text="Processing" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TitleFileName" FontSize="12" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="—" Click="Minimize_Click" Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" Width="28"/>
                        <Button x:Name="MaxBtn" Content="☐" Click="Maximize_Click"
                                Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Width="28"/>
                        <Button Content="✕" Click="Close_Click" Foreground="{DynamicResource TextSecondary}"
                                Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" Width="28"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body: two-column split -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Left: parent + patch tree -->
                <Border Grid.Column="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource BgMid}" Padding="16,10">
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"
                                       Text="{DynamicResource Proc.SelectPatches}"/>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ParentList" Margin="12,12,12,12" />
                        </ScrollViewer>

                        <!-- Loading overlay -->
                        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2"
                                Background="{DynamicResource BgDark}" Opacity="0.9" Visibility="Visible">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Pulsing dots -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                            Margin="0,0,0,14">
                                    <Ellipse Width="8" Height="8" Margin="4,0"
                                             Fill="{DynamicResource AccentButtonBg}">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                            <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0"/>
                                                            <LinearDoubleKeyFrame Value="0.2" KeyTime="0:0:0.4"/>
                                                            <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:1.2"/>
                                                        </DoubleAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <Ellipse Width="8" Height="8" Margin="4,0"
                                             Fill="{DynamicResource AccentButtonBg}">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                                                       BeginTime="0:0:0.2">
                                                            <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0"/>
                                                            <LinearDoubleKeyFrame Value="0.2" KeyTime="0:0:0.4"/>
                                                            <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:1.2"/>
                                                        </DoubleAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <Ellipse Width="8" Height="8" Margin="4,0"
                                             Fill="{DynamicResource AccentButtonBg}">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                                                       BeginTime="0:0:0.4">
                                                            <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0"/>
                                                            <LinearDoubleKeyFrame Value="0.2" KeyTime="0:0:0.4"/>
                                                            <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:1.2"/>
                                                        </DoubleAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                </StackPanel>
                                <TextBlock Text="Loading patches…" FontSize="13"
                                           Foreground="{DynamicResource TextSecondary}" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right: selection summary + actions -->
                <Border Grid.Column="1" Background="{DynamicResource BgMid}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource Border}"
                                BorderThickness="0,0,0,1">
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"
                                       Text="{DynamicResource Proc.SelectedPatches}"/>
                        </Border>

                        <!-- Selected patch queue -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="SelectedList" Margin="12,10">
                                <TextBlock x:Name="NoSelectionHint" Text="No patches selected yet."
                                           FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Action panel -->
                        <StackPanel Grid.Row="2" Margin="16,12">

                            <!-- Bypass integrity -->
                            <CheckBox x:Name="BypassCheck" Content="{DynamicResource Proc.BypassCheck}"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                      Margin="0,0,0,8"
                                      Checked="BypassCheck_Changed" Unchecked="BypassCheck_Changed"/>
                            <Border x:Name="BypassReasonPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                <TextBox x:Name="BypassReasonBox"
                                         Background="{DynamicResource BgDark}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource Border}"
                                         Padding="8,6" FontSize="12"
                                         TextWrapping="Wrap" AcceptsReturn="False"
                                         MaxLength="200"
                                         Text=""/>
                            </Border>

                            <!-- Output path -->
                            <TextBlock Text="{DynamicResource Proc.OutputFile}" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputPathBox" Grid.Column="0"
                                         Background="{DynamicResource BgDark}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource Border}"
                                         Padding="8,6" FontSize="11" IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="…" Margin="4,0,0,0"
                                        Style="{StaticResource GhostButton}" Padding="10,6"
                                        Click="BrowseOutput_Click"/>
                            </Grid>

                            <!-- Apply button -->
                            <Button x:Name="ApplyBtn" Content="{DynamicResource Proc.ApplyBtn}"
                                    Style="{StaticResource AccentButton}"
                                    Padding="0,10" FontSize="13" FontWeight="Bold"
                                    Margin="0,0,0,10"
                                    Click="Apply_Click" IsEnabled="False"/>

                            <!-- Status -->
                            <TextBlock x:Name="StatusText" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom progress bar -->
            <ProgressBar x:Name="ProgressBar" Grid.Row="2" Height="3"
                         IsIndeterminate="True" Visibility="Collapsed"
                         Foreground="{DynamicResource AccentButtonBg}"
                         Background="Transparent" BorderThickness="0"/>
        </Grid>
    </Border>
</Window>
